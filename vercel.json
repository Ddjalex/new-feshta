{
  "version": 2,

  "routes": [
    { "src": "^/api/(.*)$", "dest": "/api/index.js" },
    { "src": "^/admin/?$", "dest": "/admin/index.html" },
    { "src": "^/admin/(.*)$", "dest": "/admin/$1" },
    { "src": "^/$", "dest": "/public/index.html" },
    { "src": "^/(.*)$", "dest": "/public/$1" }
  ]
}
